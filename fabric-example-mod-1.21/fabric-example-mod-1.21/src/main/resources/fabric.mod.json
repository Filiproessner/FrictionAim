{
	"schemaVersion": 1,
	"id": "modid",
	"version": "${version}",
	"name": "Friction Aim",
	"description": "Improve your Aim with this Mod",
	"authors": [
		"Fip_Vip"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/Filiproessner/fabric-example-mod"
	},
	"license": "MIT-1.0",
	"icon": "assets/modid/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.example.ExampleMod"
		],
		"client": [
			"com.example.client.ExampleModClient"
		]
	},
	"mixins": [
		"modid.mixins.json",
		{
			"config": "modid.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}